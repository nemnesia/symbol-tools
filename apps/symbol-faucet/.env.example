# Server
PORT=3000
SYMBOL_NODE_URLS=https://001-sai-dual.symboltest.net:3001,https://t.sakia.harvestasya.com:3001,https://testnet1.symbol-mikun.net:3001
FAUCET_PRIVATE_KEY=YOUR_PRIVATE_KEY
FAUCET_TOKEN_SECRET=change_me

# CORS設定（カンマ区切りで複数指定可能）
# 未設定: 全て拒否（最も安全）
# '*': 全て許可（開発環境用のみ）
# 'https://example.com,https://another.com': 指定したオリジンのみ許可（本番推奨）
ALLOWED_ORIGINS=

# Optional faucet tuning
CLAIM_AMOUNT=55000000              # 1回の配布量（マイクロXYM）55 XYM
COOLDOWN_SECONDS=86400             # 同一アドレスへの再配布待機時間（秒）24時間
MAX_FEE=200000                     # 最大手数料（マイクロXYM）0.2 XYM
FEE_MULTIPLIER=100                 # 手数料乗数
DEADLINE_SECONDS=7200              # トランザクション有効期限（秒）2時間
MAX_DAILY_TOTAL=10000000000        # 1日の配布上限（マイクロXYM）10,000 XYM
RECENT_MINUTES=10                  # 直近監視時間（分）
RECENT_MAX=50                      # 直近の最大成功数（処理混雑時の抑制）
TOKEN_TTL_SECONDS=120              # 認証トークンの有効期限（秒）
IP_RATE_LIMIT_MINUTES=10           # IP制限の時間窓（分）
IP_RATE_LIMIT_MAX=20               # IP制限の最大リクエスト数
IP_ADDRESS_RATE_LIMIT_MINUTES=10   # IP+アドレス制限の時間窓（分）
IP_ADDRESS_RATE_LIMIT_MAX=5        # IP+アドレス制限の最大リクエスト数
IP_DAILY_LIMIT=100                 # IPごとの1日の上限

# Storage
DB_PATH=faucet.db

# Access log
LOG_DIR=logs
LOG_RETENTION_DAYS=90
